---
const navItems = [
  {
    id: "nav-extract",
    view: "view-extract",
    icon: "add_circle",
    label: "Nueva Extracción",
    active: true,
  },
  {
    id: "nav-history",
    view: "view-history",
    icon: "database",
    label: "Historial de Leads",
    active: false,
  },
  {
    id: "nav-analytics",
    view: "view-analytics",
    icon: "analytics",
    label: "Estadísticas",
    active: false,
  },
];
---

<aside
  id="sidebar-container"
  class="w-full lg:w-64 h-screen fixed left-0 top-0 bg-surface-container-lowest border-r border-outline-variant flex flex-col z-[70] transition-transform duration-300 -translate-x-full lg:translate-x-0"
>
  <div class="p-lg flex items-center justify-between border-b border-outline-variant/50">
    <div class="flex items-center gap-sm">
      <div
        class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-sm"
      >
        <span
          class="material-symbols-outlined text-on-primary"
          style="font-variation-settings: 'FILL' 1;"
        >
          bolt
        </span>
      </div>
      <h1 class="lg:font-h3 lg:text-h3 text-on-surface">DataExtract AI</h1>
    </div>

    <!-- Botón de cierre (Solo Móvil) -->
    <button
      id="close-sidebar-btn"
      class="lg:hidden w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container transition-colors text-on-surface-variant"
    >
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>

  <nav class="flex-1 p-md flex flex-col gap-xs mt-md">
    {
      navItems.map((item) => (
        <button
          id={item.id}
          class={`nav-btn w-full flex items-center gap-sm px-md py-sm rounded-xl font-label-md transition-all cursor-pointer ${
            item.active
              ? "bg-indigo-50 text-indigo-600 font-semibold"
              : "text-on-surface-variant hover:bg-surface-container  font-semibold"
          }`}
          data-view={item.view}
        >
          <span
            class="material-symbols-outlined nav-icon"
            style={item.active ? "font-variation-settings: 'FILL' 1;" : ""}
          >
            {item.icon}
          </span>
          {item.label}
        </button>
      ))
    }
  </nav>

  <div class="p-lg border-t border-outline-variant/50">
    <div class="flex items-center gap-sm">
      <div
        class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center"
      >
        <span class="material-symbols-outlined text-on-surface-variant text-sm">
          person
        </span>
      </div>
      <div>
        <p class="font-label-sm text-on-surface">Admin</p>
        <p class="font-body-sm text-xs text-on-surface-variant">Workspace</p>
      </div>
    </div>
  </div>
</aside>

<script>
  const sidebar = document.getElementById("sidebar-container");
  const closeBtn = document.getElementById("close-sidebar-btn");
  const navBtns = document.querySelectorAll(".nav-btn");

  const closeSidebar = () => {
    if (window.innerWidth < 1024) {
      sidebar?.classList.add("-translate-x-full");
    }
  };

  const openSidebar = () => {
    sidebar?.classList.remove("-translate-x-full");
  };

  // Toggle Sidebar Event
  window.addEventListener("toggle-sidebar", openSidebar);

  // Close Button
  closeBtn?.addEventListener("click", closeSidebar);

  window.addEventListener("change-view", (e: Event) => {
    const { viewId } = (e as CustomEvent).detail;

    navBtns.forEach((btn) => {
      const isTarget = btn.getAttribute("data-view") === viewId;

      if (isTarget) {
        btn.classList.remove(
          "text-on-surface-variant",
          "hover:bg-surface-container",
        );
        btn.classList.add("bg-indigo-50", "text-indigo-600", "font-semibold");
        const icon = btn.querySelector(".nav-icon");
        if (icon)
          icon.setAttribute("style", "font-variation-settings: 'FILL' 1;");
      } else {
        btn.classList.remove("bg-indigo-50", "text-indigo-600");
        btn.classList.add(
          "text-on-surface-variant",
          "hover:bg-surface-container",
          "font-semibold",
        );
        const icon = btn.querySelector(".nav-icon");
        if (icon) icon.setAttribute("style", "");
      }
    });

    // Cerrar sidebar al cambiar vista en móvil
    closeSidebar();
  });

  navBtns.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const viewId = target.getAttribute("data-view");
      window.dispatchEvent(
        new CustomEvent("change-view", { detail: { viewId } }),
      );
    });
  });

  // Cerrar al hacer clic fuera del sidebar en móvil (opcional pero recomendado)
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const isMobile = window.innerWidth < 1024;
    const isInsideSidebar = sidebar?.contains(target);
    const isMenuBtn = document.getElementById("mobile-menu-btn")?.contains(target);

    if (isMobile && !isInsideSidebar && !isMenuBtn && !sidebar?.classList.contains("-translate-x-full")) {
      closeSidebar();
    }
  });
</script>
