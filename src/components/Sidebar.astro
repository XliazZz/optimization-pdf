---
const navItems = [
  {
    id: "nav-extract",
    view: "view-extract",
    icon: "add_circle",
    label: "Nueva Extracción",
    active: true,
  },
  {
    id: "nav-history",
    view: "view-history",
    icon: "database",
    label: "Historial de Leads",
    active: false,
  },
  {
    id: "nav-analytics",
    view: "view-analytics",
    icon: "analytics",
    label: "Estadísticas",
    active: false,
  },
];
---

<aside
  class="w-64 h-screen fixed left-0 top-0 bg-surface-container-lowest border-r border-outline-variant flex flex-col z-50"
>
  <div class="p-lg flex items-center gap-sm border-b border-outline-variant/50">
    <div
      class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-sm"
    >
      <span
        class="material-symbols-outlined text-on-primary"
        style="font-variation-settings: 'FILL' 1;"
      >
        bolt
      </span>
    </div>
    <h1 class="font-h3 text-h3 text-on-surface">DataExtract AI</h1>
  </div>

  <nav class="flex-1 p-md flex flex-col gap-xs mt-md">
    {
      navItems.map((item) => (
        <button
          id={item.id}
          class={`nav-btn w-full flex items-center gap-sm px-md py-sm rounded-xl font-label-md transition-all cursor-pointer ${
            item.active
              ? "bg-indigo-50 text-indigo-600 font-semibold"
              : "text-on-surface-variant hover:bg-surface-container  font-semibold"
          }`}
          data-view={item.view}
        >
          <span
            class="material-symbols-outlined nav-icon"
            style={item.active ? "font-variation-settings: 'FILL' 1;" : ""}
          >
            {item.icon}
          </span>
          {item.label}
        </button>
      ))
    }
  </nav>

  <div class="p-lg border-t border-outline-variant/50">
    <div class="flex items-center gap-sm">
      <div
        class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center"
      >
        <span class="material-symbols-outlined text-on-surface-variant text-sm">
          person
        </span>
      </div>
      <div>
        <p class="font-label-sm text-on-surface">Admin</p>
        <p class="font-body-sm text-xs text-on-surface-variant">Workspace</p>
      </div>
    </div>
  </div>
</aside>

<script>
  const navBtns = document.querySelectorAll(".nav-btn");

  // Escuchar el evento global para sincronizar el estado visual del Sidebar
  window.addEventListener("change-view", (e: Event) => {
    const { viewId } = (e as CustomEvent).detail;
    
    navBtns.forEach((btn) => {
      const isTarget = btn.getAttribute("data-view") === viewId;
      
      if (isTarget) {
        btn.classList.remove(
          "text-on-surface-variant",
          "hover:bg-surface-container"
        );
        btn.classList.add("bg-indigo-50", "text-indigo-600", "font-semibold");
        const icon = btn.querySelector(".nav-icon");
        if (icon) icon.setAttribute("style", "font-variation-settings: 'FILL' 1;");
      } else {
        btn.classList.remove("bg-indigo-50", "text-indigo-600");
        btn.classList.add(
          "text-on-surface-variant",
          "hover:bg-surface-container",
          "font-semibold"
        );
        const icon = btn.querySelector(".nav-icon");
        if (icon) icon.setAttribute("style", "");
      }
    });
  });

  // Al hacer clic, solo emitimos el evento. El listener de arriba hará el cambio visual.
  navBtns.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const viewId = target.getAttribute("data-view");
      window.dispatchEvent(
        new CustomEvent("change-view", { detail: { viewId } }),
      );
    });
  });
</script>
