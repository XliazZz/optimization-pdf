---

---

<div
  id="pdf-viewer-panel"
  class="hidden flex-col sticky top-md"
  style="height: calc(100vh - 4rem);"
>
  <div
    class="relative flex-1 overflow-hidden border border-outline-variant shadow-md bg-surface-container-lowest"
  >
    <iframe id="pdf-iframe" class="w-full h-full" title="Vista previa del PDF"
    ></iframe>

    <div
      id="pdf-viewer-placeholder"
      class="absolute inset-0 flex flex-col items-center justify-center gap-md text-on-surface-variant"
    >
      <span
        class="material-symbols-outlined"
        style="font-size: 48px; font-variation-settings: 'FILL' 0;"
      >
        hourglass_empty
      </span>
      <p class="font-body-md">Cargando documento...</p>
    </div>
  </div>
</div>
