---

---

<div
  id="pdf-viewer-panel"
  class="hidden flex-col gap-md sticky top-md"
  style="height: calc(100vh - 4rem);"
>
  <div class="flex items-center gap-sm px-xs">
    <span
      class="material-symbols-outlined text-primary"
      style="font-variation-settings: 'FILL' 1;"
    >
      picture_as_pdf
    </span>
    <h2 class="font-h2 text-h2 text-on-surface">Documento Original</h2>
  </div>

  <div
    class="relative flex-1 rounded-2xl overflow-hidden border border-outline-variant shadow-md bg-surface-container-lowest"
  >
    <iframe
      id="pdf-iframe"
      class="w-full h-full rounded-2xl"
      title="Vista previa del PDF"></iframe>

    <div
      id="pdf-viewer-placeholder"
      class="absolute inset-0 flex flex-col items-center justify-center gap-md text-on-surface-variant"
    >
      <span
        class="material-symbols-outlined"
        style="font-size: 48px; font-variation-settings: 'FILL' 0;"
      >
        hourglass_empty
      </span>
      <p class="font-body-md">Cargando documento...</p>
    </div>
  </div>
</div>
