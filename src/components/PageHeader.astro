---
interface Props {}

const {} = Astro.props;
---

<header
  id="page-header-container"
  class="text-center space-y-md mb-xl animate-fade-in"
>
  <div
    class="inline-flex items-center gap-xs bg-primary-fixed px-md py-xs rounded-full text-on-primary-fixed mb-sm"
  >
    <span
      class="material-symbols-outlined text-lg"
      data-icon="auto_awesome"
      style="font-variation-settings: 'FILL' 1;">auto_awesome</span
    >
    <span class="font-semibold text-label-md">IA Avanzada con Gemini</span>
  </div>
  <h1 class="font-h1 text-h1 text-on-background tracking-tight">
    Gestión Inteligente de Informes
  </h1>
  <p class="font-light text-body-lg text-on-surface-variant max-w-2xl mx-auto">
    Optimiza tu flujo de trabajo subiendo tus informes PDF. Nuestra IA extraerá
    automáticamente datos clave como Empresa, Contacto y Tareas de Seguimiento
    para guardarlos directamente en Supabase.
  </p>
</header>
